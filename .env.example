# ============================================================
# LEAN AI System — Variables de entorno
# ============================================================
# Copia este archivo como .env.local para desarrollo local.
# NUNCA subas .env ni .env.local a Git.
# En Vercel: configura estas variables en Project Settings → Environment Variables.
# ============================================================

# --- Supabase (entorno DEV) ---
# Obtenidas en: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://TU_PROYECTO_DEV.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_dev_aqui

# --- Supabase (entorno PROD) ---
# Se configuran solo en Vercel (production), no en local.
# VITE_SUPABASE_URL=https://TU_PROYECTO_PROD.supabase.co
# VITE_SUPABASE_ANON_KEY=tu_anon_key_prod_aqui

# --- App config ---
VITE_APP_NAME="L.E.A.N. AI System"
VITE_APP_VERSION="0.1.0"

# --- Feature flags (MVP) ---
# Activa/desactiva features sin tocar código.
VITE_FEATURE_DARK_MODE=true
VITE_FEATURE_PDF_EXPORT=false
VITE_FEATURE_AI_ENGINE=false
